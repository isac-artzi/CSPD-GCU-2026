# ── Streamlit secrets file (EXAMPLE) ──
#
# To run the app locally using a secrets file instead of an environment
# variable:
#   1. Copy this file and rename the copy to "secrets.toml" (remove ".example")
#   2. Paste your real API key between the quotes below
#   3. Save. Never commit secrets.toml to GitHub (it is listed in .gitignore).
#
# On Streamlit Community Cloud you do NOT create this file. Instead you paste
# the same line into the app's Settings → Secrets box in your browser.

ANTHROPIC_API_KEY = "sk-ant-paste-your-real-key-here"
